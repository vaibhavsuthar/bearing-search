<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Bearing Data Finder</title>
  <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;600;700&family=Share+Tech+Mono&family=Exo+2:wght@300;400;700&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --bg: #0a0e1a;
      --surface: #111827;
      --card: #1a2235;
      --border: #1e3a5f;
      --accent: #00d4ff;
      --accent2: #ff6b00;
      --text: #e2e8f0;
      --muted: #64748b;
      --success: #00ff9f;
      --glow: 0 0 20px rgba(0,212,255,0.3);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Exo 2', sans-serif;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* Animated grid background */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(0,212,255,0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0,212,255,0.03) 1px, transparent 1px);
      background-size: 40px 40px;
      pointer-events: none;
      z-index: 0;
    }

    .container {
      position: relative;
      z-index: 1;
      max-width: 900px;
      margin: 0 auto;
      padding: 40px 20px;
    }

    /* Header */
    .header {
      text-align: center;
      margin-bottom: 50px;
    }

    .header .badge {
      display: inline-block;
      font-family: 'Share Tech Mono', monospace;
      font-size: 11px;
      color: var(--accent);
      border: 1px solid var(--accent);
      padding: 4px 14px;
      letter-spacing: 3px;
      text-transform: uppercase;
      margin-bottom: 16px;
      animation: pulse-border 2s infinite;
    }

    @keyframes pulse-border {
      0%, 100% { border-color: var(--accent); box-shadow: 0 0 10px rgba(0,212,255,0.2); }
      50% { border-color: rgba(0,212,255,0.4); box-shadow: none; }
    }

    .header h1 {
      font-family: 'Rajdhani', sans-serif;
      font-size: clamp(2rem, 6vw, 3.5rem);
      font-weight: 700;
      letter-spacing: 4px;
      text-transform: uppercase;
      background: linear-gradient(135deg, #fff 30%, var(--accent));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      line-height: 1.1;
    }

    .header p {
      margin-top: 12px;
      color: var(--muted);
      font-size: 14px;
      letter-spacing: 1px;
    }

    /* Search Box */
    .search-section {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 32px;
      margin-bottom: 32px;
      position: relative;
      overflow: hidden;
    }

    .search-section::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 2px;
      background: linear-gradient(90deg, transparent, var(--accent), transparent);
    }

    .search-label {
      font-family: 'Share Tech Mono', monospace;
      font-size: 11px;
      color: var(--accent);
      letter-spacing: 2px;
      text-transform: uppercase;
      margin-bottom: 12px;
      display: block;
    }

    .search-row {
      display: flex;
      gap: 12px;
      align-items: stretch;
    }

    .search-input {
      flex: 1;
      background: var(--bg);
      border: 1px solid var(--border);
      color: var(--text);
      font-family: 'Share Tech Mono', monospace;
      font-size: 18px;
      letter-spacing: 3px;
      padding: 14px 20px;
      outline: none;
      border-radius: 2px;
      text-transform: uppercase;
      transition: border-color 0.2s, box-shadow 0.2s;
    }

    .search-input::placeholder {
      color: var(--muted);
      letter-spacing: 2px;
      font-size: 14px;
    }

    .search-input:focus {
      border-color: var(--accent);
      box-shadow: var(--glow);
    }

    .search-btn {
      background: var(--accent);
      color: #000;
      border: none;
      padding: 14px 32px;
      font-family: 'Rajdhani', sans-serif;
      font-size: 16px;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      cursor: pointer;
      border-radius: 2px;
      transition: all 0.2s;
      white-space: nowrap;
    }

    .search-btn:hover {
      background: #fff;
      box-shadow: var(--glow);
      transform: translateY(-1px);
    }

    .search-btn:active { transform: translateY(0); }

    .search-btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
      transform: none;
    }

    /* Status Messages */
    .status {
      text-align: center;
      padding: 20px;
      font-family: 'Share Tech Mono', monospace;
      font-size: 13px;
      display: none;
    }

    .status.loading {
      display: block;
      color: var(--accent);
    }

    .status.error {
      display: block;
      color: #ff4d4d;
      background: rgba(255,77,77,0.05);
      border: 1px solid rgba(255,77,77,0.2);
      border-radius: 2px;
    }

    .status.not-found {
      display: block;
      color: var(--muted);
    }

    /* Loading dots */
    .dots::after {
      content: '';
      animation: dots 1.5s infinite;
    }
    @keyframes dots {
      0% { content: '.'; }
      33% { content: '..'; }
      66% { content: '...'; }
    }

    /* Results */
    .results-section {
      display: none;
      animation: fadeUp 0.4s ease;
    }

    .results-section.show { display: block; }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .results-header {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 20px;
    }

    .results-header .tag {
      font-family: 'Share Tech Mono', monospace;
      font-size: 11px;
      color: var(--success);
      background: rgba(0,255,159,0.08);
      border: 1px solid rgba(0,255,159,0.3);
      padding: 4px 10px;
      letter-spacing: 1px;
    }

    .results-header h2 {
      font-family: 'Rajdhani', sans-serif;
      font-size: 20px;
      font-weight: 700;
      letter-spacing: 2px;
      color: var(--text);
    }

    /* Result Card */
    .result-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 4px;
      margin-bottom: 20px;
      overflow: hidden;
      position: relative;
    }

    .result-card::before {
      content: '';
      position: absolute;
      left: 0; top: 0; bottom: 0;
      width: 3px;
      background: var(--accent);
    }

    .result-card-header {
      padding: 16px 20px 16px 24px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .bearing-number-display {
      font-family: 'Share Tech Mono', monospace;
      font-size: 22px;
      color: var(--accent);
      letter-spacing: 3px;
    }

    .type-badge {
      background: rgba(255,107,0,0.1);
      border: 1px solid rgba(255,107,0,0.4);
      color: var(--accent2);
      font-size: 12px;
      padding: 3px 12px;
      font-family: 'Rajdhani', sans-serif;
      font-weight: 600;
      letter-spacing: 1px;
      border-radius: 2px;
    }

    .data-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 0;
    }

    .data-cell {
      padding: 16px 24px;
      border-right: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      transition: background 0.15s;
    }

    .data-cell:hover { background: rgba(0,212,255,0.04); }

    .data-cell .cell-label {
      font-family: 'Share Tech Mono', monospace;
      font-size: 10px;
      color: var(--muted);
      letter-spacing: 1.5px;
      text-transform: uppercase;
      margin-bottom: 6px;
    }

    .data-cell .cell-value {
      font-family: 'Rajdhani', sans-serif;
      font-size: 18px;
      font-weight: 600;
      color: var(--text);
      letter-spacing: 1px;
    }

    .data-cell .cell-value.price {
      color: var(--success);
    }

    .data-cell .cell-value.empty {
      color: var(--muted);
      font-size: 14px;
      font-weight: 400;
    }

    /* Config section */
    .config-note {
      margin-top: 40px;
      padding: 20px;
      border: 1px dashed var(--border);
      border-radius: 4px;
      font-family: 'Share Tech Mono', monospace;
      font-size: 12px;
      color: var(--muted);
      line-height: 1.8;
    }

    .config-note span { color: var(--accent); }

    /* Footer */
    .footer {
      text-align: center;
      margin-top: 50px;
      font-family: 'Share Tech Mono', monospace;
      font-size: 11px;
      color: var(--muted);
      letter-spacing: 2px;
    }

    @media (max-width: 540px) {
      .search-row { flex-direction: column; }
      .data-grid { grid-template-columns: 1fr 1fr; }
    }
  </style>
</head>
<body>
<div class="container">

  <!-- Header -->
  <div class="header">
    <div class="badge">&#9676; Live Database</div>
    <h1>Bearing<br/>Data Finder</h1>
    <p>Enter bearing number to retrieve complete specifications</p>
  </div>

  <!-- Search -->
  <div class="search-section">
    <span class="search-label">&#9658; Search Bearing Number</span>
    <div class="search-row">
      <input
        type="text"
        class="search-input"
        id="bearingInput"
        placeholder="e.g. 6004, 6205, 7210..."
        autocomplete="off"
        onkeydown="if(event.key==='Enter') searchBearing()"
      />
      <button class="search-btn" onclick="searchBearing()" id="searchBtn">
        FIND
      </button>
    </div>
  </div>

  <!-- Status -->
  <div class="status loading" id="loadingMsg">
    <span class="dots">FETCHING DATA</span>
  </div>
  <div class="status error" id="errorMsg"></div>
  <div class="status not-found" id="notFoundMsg">
    &#9651; No bearing found with this number. Please check and try again.
  </div>

  <!-- Results -->
  <div class="results-section" id="resultsSection">
    <div class="results-header">
      <span class="tag" id="countTag"></span>
      <h2 id="resultsTitle"></h2>
    </div>
    <div id="resultsList"></div>
  </div>

  <!-- Config Note (shown only when APPS_SCRIPT_URL is not set) -->
  <div class="config-note" id="configNote">
    &#9888; <span>SETUP REQUIRED:</span> Replace <span>YOUR_APPS_SCRIPT_URL_HERE</span> in this file with your Google Apps Script Web App URL.<br/>
    See the step-by-step guide provided with this file.
  </div>

  <div class="footer">BEARING DATA SYSTEM &nbsp;&#9632;&nbsp; POWERED BY GOOGLE SHEETS</div>
</div>

<script>
  // =====================================================
  // ⚙️  YAHAN APNA APPS SCRIPT URL DAALO
  // =====================================================
  const APPS_SCRIPT_URL = "https://script.google.com/macros/s/AKfycbyItKPu0OmZ9rsXu9a-JEiQj7_FuWgIvsqnWSMJQ3Qg83D0IEbtmjEWDLlrMv-vxGStog/exec";
  // =====================================================

  window.onload = function() {
    if (APPS_SCRIPT_URL !== "YOUR_APPS_SCRIPT_URL_HERE") {
      document.getElementById('configNote').style.display = 'none';
    }
  };

  function hideAll() {
    document.getElementById('loadingMsg').style.display = 'none';
    document.getElementById('errorMsg').style.display = 'none';
    document.getElementById('notFoundMsg').style.display = 'none';
    document.getElementById('resultsSection').classList.remove('show');
  }

  async function searchBearing() {
    const input = document.getElementById('bearingInput').value.trim();
    if (!input) return;

    if (APPS_SCRIPT_URL === "YOUR_APPS_SCRIPT_URL_HERE") {
      document.getElementById('errorMsg').textContent = "⚠ Apps Script URL set nahi hai. Setup guide follow karein.";
      document.getElementById('errorMsg').style.display = 'block';
      return;
    }

    hideAll();
    document.getElementById('loadingMsg').style.display = 'block';
    document.getElementById('searchBtn').disabled = true;

    try {
      const url = `${APPS_SCRIPT_URL}?bearing=${encodeURIComponent(input.toUpperCase())}`;
      const response = await fetch(url);
      const json = await response.json();

      document.getElementById('loadingMsg').style.display = 'none';
      document.getElementById('searchBtn').disabled = false;

      if (json.status === "success" && json.data.length > 0) {
        renderResults(json.data, input.toUpperCase());
      } else {
        document.getElementById('notFoundMsg').style.display = 'block';
      }

    } catch (err) {
      document.getElementById('loadingMsg').style.display = 'none';
      document.getElementById('searchBtn').disabled = false;
      document.getElementById('errorMsg').textContent = "⚠ Connection error: " + err.message;
      document.getElementById('errorMsg').style.display = 'block';
    }
  }

  function renderResults(dataArr, bearingNo) {
    document.getElementById('countTag').textContent = dataArr.length + " RECORD" + (dataArr.length > 1 ? "S" : "") + " FOUND";
    document.getElementById('resultsTitle').textContent = "Bearing No: " + bearingNo;

    const list = document.getElementById('resultsList');
    list.innerHTML = '';

    // Columns to skip in grid (shown in header already)
    const skipCols = ['Bearing No'];
    // Price column name
    const priceCol = 'MRP';

    dataArr.forEach((row, idx) => {
      const card = document.createElement('div');
      card.className = 'result-card';

      // Card header
      const header = document.createElement('div');
      header.className = 'result-card-header';
      header.innerHTML = `
        <span class="bearing-number-display">${row['Bearing No'] || bearingNo}</span>
        ${row['Type'] ? `<span class="type-badge">${row['Type']}</span>` : ''}
      `;
      card.appendChild(header);

      // Data grid
      const grid = document.createElement('div');
      grid.className = 'data-grid';

      Object.entries(row).forEach(([key, value]) => {
        if (skipCols.includes(key) || key === 'Type') return;
        const cell = document.createElement('div');
        cell.className = 'data-cell';
        const isPrice = key === priceCol;
        const isEmpty = value === '' || value === null || value === undefined;
        cell.innerHTML = `
          <div class="cell-label">${key}</div>
          <div class="cell-value ${isPrice ? 'price' : ''} ${isEmpty ? 'empty' : ''}">
            ${isEmpty ? '—' : (isPrice ? '₹ ' + value : value)}
          </div>
        `;
        grid.appendChild(cell);
      });

      card.appendChild(grid);
      list.appendChild(card);
    });

    document.getElementById('resultsSection').classList.add('show');
  }
</script>
</body>
</html>
